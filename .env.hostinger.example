# ═══════════════════════════════════════════════════════════════
# PRODUCTION .env — Hostinger deployment
# Copy this file to `.env` on the server, then fill in the real values.
# NEVER commit the actual .env file to git.
# ═══════════════════════════════════════════════════════════════

APP_NAME="رواد بلا حدود"
APP_ENV=production
APP_KEY=                              # Generate with: php artisan key:generate
APP_DEBUG=false                       # ← MUST be false in production
APP_URL=https://rowaad.org            # ← Your actual domain (with https)

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error                       # error only in production

# ─── Database (from Hostinger hPanel → Databases) ───
DB_CONNECTION=mysql
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=u000000000_rowaad         # ← copy from hPanel
DB_USERNAME=u000000000_rowaad         # ← copy from hPanel
DB_PASSWORD=                          # ← copy from hPanel

# ─── Sessions (database driver is safest on shared hosting) ───
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.rowaad.org            # optional — enables subdomain sharing

# ─── Queue / cache (database is fine for shared) ───
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ─── Mail (Hostinger email or SMTP provider) ───
# Option 1: Hostinger's built-in email
MAIL_MAILER=smtp
MAIL_HOST=smtp.hostinger.com
MAIL_PORT=465
MAIL_USERNAME=no-reply@rowaad.org
MAIL_PASSWORD=                        # your email account password
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS="no-reply@rowaad.org"
MAIL_FROM_NAME="${APP_NAME}"

# Option 2: If using SendGrid / Postmark / Mailgun, replace the block above.

VITE_APP_NAME="${APP_NAME}"
