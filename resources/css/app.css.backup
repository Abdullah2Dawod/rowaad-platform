@import 'tailwindcss';

@source '../../vendor/laravel/framework/src/Illuminate/Pagination/resources/views/*.blade.php';
@source '../../storage/framework/views/*.php';

/* === Custom dark variant (Tailwind v4) === */
@custom-variant dark (&:where(.dark, .dark *));

@theme {
    /* === Typography — professional consulting duo ===
       Alexandria: geometric, technical → headings/display
       Almarai:    clean, highly readable → body text          */
    --font-sans:    'Almarai', ui-sans-serif, system-ui, sans-serif;
    --font-arabic:  'Almarai', ui-sans-serif, system-ui, sans-serif;
    --font-display: 'Alexandria', 'Almarai', ui-sans-serif, system-ui, sans-serif;

    /* === NAVY (logo deep R) === */
    --color-navy-50:   #F0F4FA;
    --color-navy-100:  #DCE5F1;
    --color-navy-200:  #B8CCE3;
    --color-navy-300:  #8FAED1;
    --color-navy-400:  #6790BF;
    --color-navy-500:  #4575AC;
    --color-navy-600:  #2D4B7E;
    --color-navy-700:  #233E68;
    --color-navy-800:  #1A2F50;
    --color-navy-900:  #122440;
    --color-navy-950:  #0A1729;

    /* === TEAL (logo loop) === */
    --color-teal-50:   #E6F7F8;
    --color-teal-100:  #C2EBEF;
    --color-teal-200:  #95DCE3;
    --color-teal-300:  #6BC8D2;
    --color-teal-400:  #4FB7C0;
    --color-teal-500:  #3DAFB9;
    --color-teal-600:  #2E8C95;
    --color-teal-700:  #226A72;
    --color-teal-800:  #18505A;
    --color-teal-900:  #103339;
}

/* === SEMANTIC THEME TOKENS (switchable Light/Dark) === */
:root {
    --bg-paper:        #FFFFFF;
    --bg-canvas:       #F8FAFC;
    --bg-mist:         #F1F5F9;
    --bg-elevated:     #FFFFFF;
    --bg-accent:       rgba(61, 175, 185, 0.08);

    --border-soft:     #E5EEF2;
    --border-muted:    #E2E8F0;
    --border-brand:    rgba(61, 175, 185, 0.30);

    --ink-primary:     #0A1729;
    --ink-strong:      #2D4B7E;
    --ink-body:        #475569;
    --ink-muted:       #94A3B8;
    --ink-faint:       #CBD5E1;

    --brand-teal:      #3DAFB9;
    --brand-teal-soft: #6BC8D2;
    --brand-navy:      #2D4B7E;

    --shadow-color:    45, 75, 126;
    --shadow-strength: 0.08;
}

html.dark {
    --bg-paper:        #0A1729;
    --bg-canvas:       #122440;
    --bg-mist:         #1A2F50;
    --bg-elevated:     #122440;
    --bg-accent:       rgba(61, 175, 185, 0.12);

    --border-soft:     rgba(255, 255, 255, 0.08);
    --border-muted:    rgba(255, 255, 255, 0.06);
    --border-brand:    rgba(61, 175, 185, 0.35);

    --ink-primary:     #FFFFFF;
    --ink-strong:      #C2EBEF;
    --ink-body:        rgba(255, 255, 255, 0.70);
    --ink-muted:       rgba(255, 255, 255, 0.50);
    --ink-faint:       rgba(255, 255, 255, 0.30);

    --brand-teal:      #6BC8D2;
    --brand-teal-soft: #95DCE3;
    --brand-navy:      #8FAED1;

    --shadow-color:    0, 0, 0;
    --shadow-strength: 0.35;
}

@layer base {
    html {
        scroll-behavior: smooth;
        background: var(--bg-paper);
        transition: background 500ms ease;
    }

    body {
        /* Body text: Almarai (clean & readable) */
        font-family: var(--font-arabic);
        background: var(--bg-paper);
        color: var(--ink-primary);
        /* overflow-x: clip (NOT hidden) so position: sticky continues to work */
        overflow-x: clip;
        -webkit-font-smoothing: antialiased;
        -moz-osx-font-smoothing: grayscale;
        transition: background 500ms ease, color 500ms ease;
    }

    /* Headings & display text: Alexandria (geometric, technical, consulting-grade) */
    h1, h2, h3, h4, h5, h6,
    .font-display {
        font-family: var(--font-display);
        letter-spacing: -0.01em;
    }

    ::selection {
        background: var(--brand-teal);
        color: white;
    }

    ::-webkit-scrollbar { width: 10px; height: 10px; }
    ::-webkit-scrollbar-track { background: var(--bg-canvas); }
    ::-webkit-scrollbar-thumb {
        background: linear-gradient(to bottom, var(--brand-navy), var(--brand-teal));
        border-radius: 5px;
        border: 2px solid var(--bg-canvas);
    }
}

@layer utilities {
    /* === Theme-aware utility classes === */
    .bg-paper    { background-color: var(--bg-paper); }
    .bg-canvas   { background-color: var(--bg-canvas); }
    .bg-mist     { background-color: var(--bg-mist); }
    .bg-elevated { background-color: var(--bg-elevated); }
    .border-soft   { border-color: var(--border-soft); }
    .border-muted  { border-color: var(--border-muted); }
    .border-brand  { border-color: var(--border-brand); }
    .text-ink      { color: var(--ink-primary); }
    .text-ink-strong { color: var(--ink-strong); }
    .text-ink-body { color: var(--ink-body); }
    .text-ink-muted { color: var(--ink-muted); }
    .text-ink-faint { color: var(--ink-faint); }

    /* === Brand gradients - dynamic === */
    .text-gradient-brand {
        background: linear-gradient(135deg, var(--brand-navy) 0%, var(--brand-teal) 50%, var(--brand-teal-soft) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .text-gradient {
        background: linear-gradient(135deg, var(--brand-navy) 0%, var(--brand-teal) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .text-gradient-teal {
        background: linear-gradient(135deg, #2E8C95 0%, #4FB7C0 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .bg-brand-gradient {
        background: linear-gradient(135deg, #2D4B7E 0%, #3DAFB9 100%);
    }

    .bg-glass {
        background: rgba(255, 255, 255, 0.75);
        backdrop-filter: blur(20px) saturate(180%);
        -webkit-backdrop-filter: blur(20px) saturate(180%);
    }
    html.dark .bg-glass {
        background: rgba(18, 36, 64, 0.65);
    }

    /* === Background patterns - theme aware === */
    .grid-pattern {
        background-image:
            linear-gradient(rgba(45, 75, 126, 0.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(45, 75, 126, 0.04) 1px, transparent 1px);
        background-size: 80px 80px;
    }
    html.dark .grid-pattern {
        background-image:
            linear-gradient(rgba(107, 200, 210, 0.05) 1px, transparent 1px),
            linear-gradient(90deg, rgba(107, 200, 210, 0.05) 1px, transparent 1px);
    }

    .dot-pattern {
        background-image: radial-gradient(rgba(61, 175, 185, 0.12) 1.2px, transparent 1.2px);
        background-size: 24px 24px;
    }
    html.dark .dot-pattern {
        background-image: radial-gradient(rgba(107, 200, 210, 0.15) 1.2px, transparent 1.2px);
    }

    /* === Premium shadows - theme aware === */
    .shadow-card {
        box-shadow:
            0 1px 2px rgba(var(--shadow-color), calc(var(--shadow-strength) * 0.5)),
            0 4px 16px rgba(var(--shadow-color), calc(var(--shadow-strength) * 0.75)),
            0 12px 40px rgba(var(--shadow-color), calc(var(--shadow-strength) * 0.5));
    }
    .shadow-card-hover {
        box-shadow:
            0 4px 12px rgba(var(--shadow-color), calc(var(--shadow-strength) * 1)),
            0 16px 48px rgba(61, 175, 185, 0.12),
            0 32px 80px rgba(var(--shadow-color), calc(var(--shadow-strength) * 0.75));
    }
    .shadow-brand {
        box-shadow: 0 20px 60px -10px rgba(61, 175, 185, 0.30);
    }

    .logo-glow {
        filter: drop-shadow(0 6px 24px rgba(45, 75, 126, 0.15)) drop-shadow(0 2px 6px rgba(61, 175, 185, 0.20));
    }
    html.dark .logo-glow {
        filter: drop-shadow(0 8px 32px rgba(61, 175, 185, 0.35)) drop-shadow(0 2px 8px rgba(107, 200, 210, 0.30));
    }

    /* === Link underline === */
    .link-underline {
        position: relative;
    }
    .link-underline::after {
        content: '';
        position: absolute;
        left: 50%;
        bottom: -4px;
        width: 0;
        height: 2px;
        background: linear-gradient(to right, var(--brand-teal), var(--brand-navy));
        transition: all 0.35s cubic-bezier(0.4, 0, 0.2, 1);
        transform: translateX(-50%);
        border-radius: 2px;
    }
    .link-underline:hover::after {
        width: 70%;
    }
}

/* === KEYFRAMES === */

/* ==================================================================
 * SEAMLESS INFINITE MARQUEE — standard technique
 * ------------------------------------------------------------------
 *   HTML: two identical copies of content side by side
 *   CSS:  animate translateX from 0 → -50% (one full copy width)
 *   Result: when copy A scrolls fully out, copy B sits in copy A's
 *           original position; the loop restarts invisibly because
 *           pixel-position at 100% equals pixel-position at 0%.
 * ================================================================== */
@keyframes ticker-ltr {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}
@keyframes ticker-rtl {
    0%   { transform: translateX(0); }
    100% { transform: translateX(50%); }
}

.marquee-track {
    display: flex;
    width: max-content;
    flex-shrink: 0;
    animation: ticker-ltr 32s linear infinite;
    animation-play-state: running !important;
    will-change: transform;
    backface-visibility: hidden;
}
[dir="rtl"] .marquee-track {
    animation-name: ticker-rtl;
}

/* Pause on hover so the visitor can read */
.marquee-track:hover {
    animation-play-state: paused !important;
}

/* Legacy alias for any other marquee uses */
@keyframes marquee {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
}
@keyframes marquee-reverse {
    0%   { transform: translateX(0); }
    100% { transform: translateX(50%); }
}
.animate-marquee {
    animation: marquee 32s linear infinite;
    animation-play-state: running !important;
    will-change: transform;
}
[dir="rtl"] .animate-marquee {
    animation-name: marquee-reverse;
}

@keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-12px); }
}

@keyframes floatParticle {
    0%, 100% { transform: translate(0, 0); opacity: 0.5; }
    25% { transform: translate(15px, -25px); opacity: 0.8; }
    50% { transform: translate(-10px, -40px); opacity: 0.3; }
    75% { transform: translate(20px, -15px); opacity: 0.7; }
}

@keyframes floatingElement {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(-10px, -15px) rotate(-1deg); }
    66% { transform: translate(8px, -8px) rotate(1deg); }
}
.floating-element { animation: floatingElement 10s ease-in-out infinite; }

@keyframes glow-pulse {
    0%, 100% { filter: drop-shadow(0 4px 16px rgba(61, 175, 185, 0.20)); }
    50% { filter: drop-shadow(0 8px 32px rgba(61, 175, 185, 0.40)); }
}
.logo-pulse { animation: glow-pulse 4s ease-in-out infinite; }

/* Editorial badge accent — animated vertical bar */
@keyframes barPulse {
    0%, 100% { transform: scaleY(1); opacity: 1; }
    50% { transform: scaleY(0.5); opacity: 0.5; }
}
.bar-pulse { animation: barPulse 2.5s ease-in-out infinite; transform-origin: center; }

/* Sparkle rotation for brand mark */
@keyframes brandSpin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
}
.brand-spin { animation: brandSpin 20s linear infinite; }

/* Testimonial avatar progress ring (6s = autoplay interval) */
@keyframes testimonialRing {
    from { stroke-dashoffset: 113; }
    to   { stroke-dashoffset: 0; }
}

/* === LIVE CONSULTATION CHAT (testimonials) === */
/* Typing indicator: visible ~1.1s then fades out */
@keyframes chatTyping {
    0%, 60%  { opacity: 1; transform: translateY(0); }
    78%, 100%{ opacity: 0; transform: translateY(6px); height: 0; margin: 0; }
}
.chat-typing {
    animation: chatTyping 1.5s ease-out both;
    overflow: hidden;
}
/* Typing dots bounce */
@keyframes typingDot {
    0%, 60%, 100% { transform: translateY(0); opacity: .6; }
    30%           { transform: translateY(-4px); opacity: 1; }
}
.typing-dot { animation: typingDot 1s ease-in-out infinite; }

/* Bubble pops in after typing finishes */
@keyframes chatBubble {
    0%, 62% { opacity: 0; transform: translateY(14px) scale(0.96); }
    80%     { opacity: 1; transform: translateY(-2px) scale(1.01); }
    100%    { opacity: 1; transform: translateY(0) scale(1); }
}
.chat-bubble { animation: chatBubble 1.9s cubic-bezier(0.22, 1, 0.36, 1) both; }

/* === FLOATING CONSULTATION BEACON — clean & simple === */

/* Soft breathing halo */
@keyframes fabHalo {
    0%, 100% { transform: scale(1);    opacity: 0.5; }
    50%      { transform: scale(1.35); opacity: 0;   }
}
.fab-halo { animation: fabHalo 2.4s ease-out infinite; }

/* Core button — smooth hover lift & grow */
.fab-core {
    transition: transform 300ms cubic-bezier(0.34, 1.4, 0.5, 1),
                box-shadow 300ms ease;
}
.fab-beacon:hover .fab-core {
    transform: scale(1.08);
    box-shadow: 0 10px 28px -6px rgba(61, 175, 185, 0.55);
}

/* Label: hidden by default, slides open smoothly on hover */
.fab-label {
    max-width: 0;
    opacity: 0;
    transform: translateX(8px);
    transition: max-width 400ms cubic-bezier(0.22, 1, 0.36, 1),
                opacity 300ms ease-out,
                transform 400ms cubic-bezier(0.22, 1, 0.36, 1);
    will-change: max-width, opacity, transform;
}
.fab-beacon:hover .fab-label {
    max-width: 280px;
    opacity: 1;
    transform: translateX(0);
}

/* Pill polish on hover */
.fab-pill {
    transition: border-color 250ms ease, box-shadow 250ms ease;
}
.fab-beacon:hover .fab-pill {
    border-color: rgba(61, 175, 185, 0.45);
    box-shadow: 0 8px 24px -8px rgba(61, 175, 185, 0.35);
}

/* Arrow slides on hover */
.fab-arrow { transition: transform 250ms ease; }
.fab-beacon:hover .fab-arrow { transform: translateX(-3px); }

/* === Generic scroll-reveal (used by inner pages) === */
[data-reveal] {
    opacity: 0;
    transform: translateY(26px);
    transition: opacity 700ms cubic-bezier(0.16, 1, 0.3, 1), transform 700ms cubic-bezier(0.16, 1, 0.3, 1);
}
[data-reveal].revealed {
    opacity: 1;
    transform: translateY(0);
}

/* === Lively drifting aurora background (mirsal-inspired, brand-toned) === */
@keyframes auroraDrift {
    0%   { transform: translate(0, 0) scale(1); }
    33%  { transform: translate(3%, -4%) scale(1.06); }
    66%  { transform: translate(-3%, 3%) scale(0.97); }
    100% { transform: translate(0, 0) scale(1); }
}
.aurora-drift { animation: auroraDrift 16s ease-in-out infinite; }

/* Conic gradient spin for premium border effect */
@keyframes conicSpin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
}

/* Sector featured content swap — smooth cross-fade with slight slide */
.sector-swap-enter-active,
.sector-swap-leave-active {
    transition: opacity 500ms cubic-bezier(0.4, 0, 0.2, 1), transform 500ms cubic-bezier(0.4, 0, 0.2, 1);
}
.sector-swap-enter-from {
    opacity: 0;
    transform: translateY(16px);
}
.sector-swap-leave-to {
    opacity: 0;
    transform: translateY(-16px);
}

/* Sector icon swap — scale + fade */
.sector-icon-enter-active,
.sector-icon-leave-active {
    transition: opacity 500ms cubic-bezier(0.34, 1.56, 0.64, 1), transform 500ms cubic-bezier(0.34, 1.56, 0.64, 1);
}
.sector-icon-enter-from {
    opacity: 0;
    transform: scale(0.6) rotate(-30deg);
}
.sector-icon-leave-to {
    opacity: 0;
    transform: scale(1.3) rotate(30deg);
}

/* Methodology traveling dot along connector line */
@keyframes methodDot {
    0%   { left: 0%;   transform: translateY(-50%) scale(1); opacity: 0; }
    10%  { opacity: 1; transform: translateY(-50%) scale(1); }
    50%  { transform: translateY(-50%) scale(1.4); }
    90%  { opacity: 1; transform: translateY(-50%) scale(1); }
    100% { left: 100%; transform: translateY(-50%) scale(1); opacity: 0; }
}
[dir="rtl"] {
    @keyframes methodDot {
        0%   { right: 0%;  transform: translateY(-50%) scale(1); opacity: 0; }
        10%  { opacity: 1; transform: translateY(-50%) scale(1); }
        50%  { transform: translateY(-50%) scale(1.4); }
        90%  { opacity: 1; transform: translateY(-50%) scale(1); }
        100% { right: 100%; transform: translateY(-50%) scale(1); opacity: 0; }
    }
}

/* === ORBITAL ROTATION KEYFRAMES === */
@keyframes orbit-inner-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
}
@keyframes orbit-inner-counter {
    from { transform: rotate(0deg); }
    to   { transform: rotate(-360deg); }
}
.orbit-inner-spin    { animation: orbit-inner-spin 50s linear infinite; transform-origin: center; }
.orbit-inner-counter { animation: orbit-inner-counter 50s linear infinite; transform-origin: center; }

@keyframes orbit-outer-spin {
    from { transform: rotate(0deg); }
    to   { transform: rotate(-360deg); }
}
@keyframes orbit-outer-counter {
    from { transform: rotate(0deg); }
    to   { transform: rotate(360deg); }
}
.orbit-outer-spin    { animation: orbit-outer-spin 100s linear infinite; transform-origin: center; }
.orbit-outer-counter { animation: orbit-outer-counter 100s linear infinite; transform-origin: center; }

/* === Smooth theme transitions === */
.theme-transition,
.theme-transition *,
.theme-transition *::before,
.theme-transition *::after {
    transition: background-color 400ms ease, color 400ms ease, border-color 400ms ease, fill 400ms ease, stroke 400ms ease !important;
    transition-delay: 0 !important;
}

.reveal-up { opacity: 0; transform: translateY(40px); }
.reveal-fade { opacity: 0; }

/* === Expertise section transitions — fast, snappy, professional === */

/* Illustration cross-fade — quick with subtle scale (no blur, no heavy motion) */
.illust-enter-active,
.illust-leave-active {
    transition: opacity 350ms cubic-bezier(0.4, 0, 0.2, 1), transform 350ms cubic-bezier(0.4, 0, 0.2, 1);
}
.illust-enter-from {
    opacity: 0;
    transform: scale(0.95);
}
.illust-leave-to {
    opacity: 0;
    transform: scale(1.03);
}

/* Big number swap — fast fade with tiny slide */
.bignum-enter-active,
.bignum-leave-active {
    transition: opacity 350ms cubic-bezier(0.4, 0, 0.2, 1), transform 350ms cubic-bezier(0.4, 0, 0.2, 1);
}
.bignum-enter-from {
    opacity: 0;
    transform: translateY(15px);
}
.bignum-leave-to {
    opacity: 0;
    transform: translateY(-15px);
}

/* Tags/titles — snappy */
.fade-swap-enter-active,
.fade-swap-leave-active {
    transition: opacity 300ms ease-out, transform 300ms ease-out;
}
.fade-swap-enter-from {
    opacity: 0;
    transform: translateY(6px);
}
.fade-swap-leave-to {
    opacity: 0;
    transform: translateY(-6px);
}
